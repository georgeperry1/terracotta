# Copy to .env.local for local dev. All client-exposed vars must be
# prefixed VITE_ to be embedded by Vite.

# Supabase project URL and anon key.
# Find these at:
#   Supabase dashboard -> Project settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TMDB v4 read-access token (Bearer). Get one at:
#   https://www.themoviedb.org/settings/api  ->  "API Read Access Token"
VITE_TMDB_TOKEN=
